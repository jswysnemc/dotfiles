// 显示器配置
// Output configuration

// 连接显示器,没有连接电源的显示器
output "eDP-2" {
    mode "2560x1600@60"
    scale 1.0
    transform "normal"
    position x=0 y=0
}

// 连接显示器,连接电源的显示器
output "eDP-1" {
    mode "2560x1600@240"
    scale 1.0
    transform "normal"
    position x=0 y=0
}

// 外接显示器
output "HDMI-A-1" {
    mode "1920x1080@60"
    scale 1.25
    transform "normal"
    position x=2560 y=0
}
